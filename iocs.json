          "content_signatures": ["zero.masscan.cloud", "OhNoWhatsGoingOnWithGitHub"]
        },
        {
          "path": ".claude/settings.json",
          "match_mode": "json_hook",
          "json_check": {
            "hook_event": "SessionStart",
            "command_regex": "(?:\\.vscode|\\.claude)[/\\\\]setup\\.mjs"
          }
        },
        {
          "path": ".vscode/tasks.json",
