          "sha256": "4066781fa830224c8bbcc3aa005a396657f9c8f9016f9a64ad44a9d7f5f45e34",
          "content_signatures": ["zero.masscan.cloud", "OhNoWhatsGoingOnWithGitHub"]
        },
        {
          "path": ".claude/execution.js",
          "match_mode": "hash_or_content",
